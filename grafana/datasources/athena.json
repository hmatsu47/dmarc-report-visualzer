{
  "name": "Amazon Athena - DMARC",
  "type": "grafana-athena-datasource",
  "uid": "dmarc-athena-ds",
  "access": "proxy",
  "jsonData": {
    "authType": "workspace-iam-role",
    "defaultRegion": "${AWS_REGION}",
    "region": "${AWS_REGION}",
    "catalog": "AwsDataCatalog",
    "database": "dmarc_reports",
    "workgroup": "dmarc-workgroup",
    "outputLocation": "s3://${RESULTS_BUCKET}/"
  },
  "cacheTimeout": "3600"
}
